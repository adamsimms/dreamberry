# Dreamberry local secrets (never commit). Copy to `.env` and fill in.

# Hugging Face (model downloads)
HF_TOKEN=

# Cloudflare R2 — dedicated bucket art-adamsimms-xyz-dreamberry
# S3 API endpoint (NOT the public custom domain):
CF_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET=
CF_R2_BUCKET=art-adamsimms-xyz-dreamberry
# Public custom domain or r2.dev base (no trailing slash):
CF_R2_PUBLIC_BASE_URL=https://dreamberry.adamsimms.xyz
# Optional: account API token (not required for S3 writes)
CF_R2_API_TOKEN=

# healthchecks.io dead-man ping URL
HEALTH_PING_URL=https://hc-ping.com/<uuid>
